<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:padding="24dp" android:background="@color/bg_card">
    <EditText android:id="@+id/etUsername"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:hint="Username" android:inputType="text"
        android:backgroundTint="@color/divider" android:textColor="@color/text_main"
        android:layout_marginBottom="16dp"/>
    <EditText android:id="@+id/etPassword"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:hint="Password" android:inputType="textPassword"
        android:backgroundTint="@color/divider" android:textColor="@color/text_main"
        android:layout_marginBottom="24dp"/>
    <Button android:id="@+id/btnLogin"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Sign In" android:backgroundTint="@color/brand_cyan"/>
</LinearLayout>
