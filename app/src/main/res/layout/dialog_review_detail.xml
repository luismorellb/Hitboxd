<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/bg_card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/dialog_review_detail_title"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_main"
            android:layout_marginBottom="16dp"/>

        <!-- Review ID -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:text="@string/label_review_id"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"/>

            <TextView
                android:id="@+id/tvDetailReviewId"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/text_main"
                android:textSize="13sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Game -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:text="@string/label_game"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"/>

            <TextView
                android:id="@+id/tvDetailGame"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/brand_cyan"
                android:textSize="13sp"/>
        </LinearLayout>

        <!-- User -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:text="@string/label_user"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"/>

            <TextView
                android:id="@+id/tvDetailUser"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/text_main"
                android:textSize="13sp"/>
        </LinearLayout>

        <!-- Created at -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:text="@string/label_created_at"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"/>

            <TextView
                android:id="@+id/tvDetailDate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/text_main"
                android:textSize="13sp"/>
        </LinearLayout>

        <!-- Reports count -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:text="@string/label_reports"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"/>

            <TextView
                android:id="@+id/tvDetailReportCount"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/brand_red"
                android:textStyle="bold"
                android:textSize="13sp"/>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginBottom="12dp"/>

        <!-- Content -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_content"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tvDetailContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_main"
            android:textSize="13sp"
            android:minLines="3"
            android:background="@color/bg_light"
            android:padding="8dp"
            android:layout_marginBottom="12dp"/>

        <!-- Report reasons -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_report_reasons"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tvDetailReasons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/brand_red"
            android:textSize="13sp"
            android:background="@color/bg_light"
            android:padding="8dp"
            android:layout_marginBottom="20dp"/>

        <Button
            android:id="@+id/btnClose"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/action_close"
            android:backgroundTint="@color/bg_panel_dark"
            android:textColor="@color/text_white"/>

    </LinearLayout>
</ScrollView>
