<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:padding="12dp"
    android:layout_marginBottom="4dp" android:background="@color/bg_card">
    <TextView android:id="@+id/tvPosition"
        android:layout_width="28dp" android:layout_height="wrap_content"
        android:layout_gravity="center_vertical" android:textColor="@color/text_muted"
        android:textSize="12sp" android:layout_marginEnd="8dp"/>
    <ImageView android:id="@+id/imgCover"
        android:layout_width="50dp" android:layout_height="70dp"
        android:scaleType="centerCrop" android:layout_marginEnd="12dp"/>
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical" android:layout_gravity="center_vertical">
        <TextView android:id="@+id/tvTitle"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textStyle="bold" android:textColor="@color/text_main" android:textSize="14sp"
            android:maxLines="2" android:ellipsize="end"/>
        <TextView android:id="@+id/tvComment"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="@color/text_secondary" android:textSize="12sp"
            android:maxLines="2" android:ellipsize="end"/>
    </LinearLayout>
</LinearLayout>
