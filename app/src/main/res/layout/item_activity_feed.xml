<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:padding="12dp"
    android:layout_marginBottom="4dp" android:background="@color/bg_card">
    <ImageView android:id="@+id/imgCover"
        android:layout_width="48dp" android:layout_height="64dp"
        android:scaleType="centerCrop" android:layout_marginEnd="12dp"/>
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical">
        <TextView android:id="@+id/tvUsername"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textStyle="bold" android:textColor="@color/text_main"/>
        <TextView android:id="@+id/tvStatus"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/brand_cyan" android:textSize="12sp"/>
        <TextView android:id="@+id/tvGameTitle"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/text_secondary" android:textSize="13sp"/>
        <TextView android:id="@+id/tvDate"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/text_muted" android:textSize="11sp"/>
    </LinearLayout>
</LinearLayout>
