<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:padding="24dp" android:gravity="center"
    android:background="@color/bg_light">
    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Danger Zone" android:textSize="22sp" android:textStyle="bold"
        android:textColor="@color/brand_red" android:gravity="center" android:layout_marginBottom="12dp"/>
    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Deleting your account is permanent and cannot be undone. All your data, reviews and lists will be removed."
        android:textColor="@color/text_secondary" android:gravity="center"
        android:layout_marginBottom="32dp"/>
    <Button android:id="@+id/btnDeleteAccount"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Delete My Account"
        android:backgroundTint="@color/brand_red"/>
</LinearLayout>
