<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:layout_marginBottom="4dp"
    android:background="@color/bg_card"
    android:gravity="center_vertical">

    <ImageView
        android:id="@+id/imgAvatar"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:scaleType="centerCrop"
        android:contentDescription="@string/content_desc_avatar"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp">

        <TextView
            android:id="@+id/tvUsername"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:textColor="@color/text_main"
            android:textSize="14sp"/>

        <TextView
            android:id="@+id/tvEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/text_muted"/>

        <TextView
            android:id="@+id/tvBanned"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/admin_user_banned"
            android:textColor="@color/text_white"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="@drawable/badge_red"
            android:layout_marginTop="2dp"
            android:visibility="gone"/>
    </LinearLayout>

    <Button
        android:id="@+id/btnToggleBan"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/admin_btn_ban"
        android:textSize="12sp"/>

</LinearLayout>
