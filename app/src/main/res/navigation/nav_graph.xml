<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFeedFragment">

    <fragment
        android:id="@+id/homeFeedFragment"
        android:name="com.hitboxd.app.ui.home.HomeFeedFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home_feed">
        <action
            android:id="@+id/action_homeFeedFragment_to_gameDetailFragment"
            app:destination="@id/gameDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/gameDetailFragment"
        android:name="com.hitboxd.app.ui.game.GameDetailFragment"
        android:label="Game"
        tools:layout="@layout/fragment_game_detail">
        <argument
            android:name="slug"
            app:argType="string" />
        <action
            android:id="@+id/action_gameDetailFragment_to_publicProfileFragment"
            app:destination="@id/publicProfileFragment" />
        <action
            android:id="@+id/action_gameDetailFragment_self"
            app:destination="@id/gameDetailFragment"
            app:popUpTo="@id/gameDetailFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/catalogFragment"
        android:name="com.hitboxd.app.ui.catalog.CatalogFragment"
        android:label="Catalog"
        tools:layout="@layout/fragment_catalog">
        <action
            android:id="@+id/action_catalogFragment_to_gameDetailFragment"
            app:destination="@id/gameDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/trackerFragment"
        android:name="com.hitboxd.app.ui.tracker.TrackerFragment"
        android:label="Tracker"
        tools:layout="@layout/fragment_tracker">
        <action
            android:id="@+id/action_trackerFragment_to_gameDetailFragment"
            app:destination="@id/gameDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.hitboxd.app.ui.profile.ProfileFragment"
        android:label="Profile"
        tools:layout="@layout/fragment_profile">
        <action
            android:id="@+id/action_profileFragment_to_gameDetailFragment"
            app:destination="@id/gameDetailFragment" />
        <action
            android:id="@+id/action_profileFragment_to_publicProfileFragment"
            app:destination="@id/publicProfileFragment" />
        <action
            android:id="@+id/action_profileFragment_to_listDetailFragment"
            app:destination="@id/listDetailFragment" />
        <action
            android:id="@+id/action_profileFragment_to_settingsFragment"
            app:destination="@id/settingsFragment" />
        <action
            android:id="@+id/action_profileFragment_to_adminFragment"
            app:destination="@id/adminFragment" />
    </fragment>

    <fragment
        android:id="@+id/publicProfileFragment"
        android:name="com.hitboxd.app.ui.publicprofile.PublicProfileFragment"
        android:label="Profile"
        tools:layout="@layout/fragment_public_profile">
        <argument
            android:name="username"
            app:argType="string" />
        <action
            android:id="@+id/action_publicProfileFragment_to_gameDetailFragment"
            app:destination="@id/gameDetailFragment" />
        <action
            android:id="@+id/action_publicProfileFragment_to_listDetailFragment"
            app:destination="@id/listDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/listDetailFragment"
        android:name="com.hitboxd.app.ui.listdetail.ListDetailFragment"
        android:label="List"
        tools:layout="@layout/fragment_list_detail">
        <argument
            android:name="listId"
            app:argType="integer" />
        <action
            android:id="@+id/action_listDetailFragment_to_gameDetailFragment"
            app:destination="@id/gameDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.hitboxd.app.ui.settings.SettingsFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_settings" />

    <fragment
        android:id="@+id/adminFragment"
        android:name="com.hitboxd.app.ui.admin.AdminFragment"
        android:label="Admin"
        tools:layout="@layout/fragment_admin">
        <action
            android:id="@+id/action_adminFragment_to_gameDetailFragment"
            app:destination="@id/gameDetailFragment" />
    </fragment>

</navigation>